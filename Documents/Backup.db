-- ============================================================
-- NHÓM A: DỮ LIỆU ĐỊNH HƯỚNG NGHỀ NGHIỆP (HỆ THỐNG)
-- ============================================================

-- 1. Bảng career_tracks: Danh mục các ngành nghề hướng nghiệp
CREATE TABLE career_tracks (
    id              SERIAL PRIMARY KEY,
    career_track    VARCHAR(100)    NOT NULL,               -- "Data Science", "Kỹ thuật Ô tô"
    track_type      VARCHAR(20)     NOT NULL                -- "academic" | "vocational"
                    CHECK (track_type IN ('academic', 'vocational')),
    description     TEXT,
    avg_salary_min  INTEGER,                                -- VND/tháng
    avg_salary_max  INTEGER,
    education_route TEXT,                                   -- "Đại học CNTT" | "Cao đẳng nghề 2 năm"
    typical_employers TEXT[],                               -- ["FPT", "VNG", "Viettel"]
    region_demand   JSONB,                                  -- { "HCM": "high", "HN": "medium" }
    vector_id       VARCHAR(100),                           -- ID trong Pinecone (để đối chiếu)
    created_at      TIMESTAMP DEFAULT NOW()
);

-- 2. Bảng role_progressions: Lộ trình vị trí công việc của từng career track
CREATE TABLE role_progressions (
    id              SERIAL PRIMARY KEY,
    career_track_id INTEGER NOT NULL REFERENCES career_tracks(id) ON DELETE CASCADE,
    level           VARCHAR(20) NOT NULL                    -- "Entry" | "Mid" | "Advanced"
                    CHECK (level IN ('Entry', 'Mid', 'Advanced')),
    title           VARCHAR(150) NOT NULL,                  -- "Data Analyst Intern"
    description     TEXT,
    sort_order      INTEGER DEFAULT 0                       -- thứ tự hiển thị
);

-- 3. Bảng skill_trees: Kỹ năng cần thiết theo từng career track
CREATE TABLE skill_trees (
    id              SERIAL PRIMARY KEY,
    career_track_id INTEGER NOT NULL REFERENCES career_tracks(id) ON DELETE CASCADE,
    category        VARCHAR(50) NOT NULL                    -- "fundamentals" | "core_technologies" | "advanced_skills"
                    CHECK (category IN ('fundamentals', 'core_technologies', 'advanced_skills')),
    skill_name      VARCHAR(100) NOT NULL                   -- "Python", "PLC Siemens", "SQL"
);


-- ============================================================
-- NHÓM B: DỮ LIỆU NGƯỜI DÙNG & TIẾN TRÌNH CHAT AI (NestJS ghi)
-- ============================================================

-- 4. Bảng users: Quản lý tài khoản (Đăng ký hoặc ẩn danh)
CREATE TABLE users (
    id              SERIAL PRIMARY KEY,
    username        VARCHAR(100) UNIQUE,                    -- Dùng cho login (custom JWT Auth)
    email           VARCHAR(255) UNIQUE NOT NULL,           -- Email đăng ký tài khoản
    password_hash   VARCHAR(255) NOT NULL,                  -- Mật khẩu mã hóa lưu trên DB của NestJS
    anonymous_id    UUID UNIQUE,                            -- Dùng để định danh nếu là khách vãng lai
    created_at      TIMESTAMP DEFAULT NOW()
);

-- 5. Bảng sessions: Phiên trò chuyện của học sinh
CREATE TABLE sessions (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         INTEGER REFERENCES users(id) ON DELETE SET NULL,
    started_at      TIMESTAMP DEFAULT NOW(),
    ended_at        TIMESTAMP,
    is_complete     BOOLEAN DEFAULT FALSE                   -- true khi đã generate xong roadmap cho học sinh
);

-- 6. Bảng conversation_messages: Backup lịch sử chat (Redis là primary, PostgreSQL để lưu trữ lâu dài)
CREATE TABLE conversation_messages (
    id              SERIAL PRIMARY KEY,
    session_id      UUID NOT NULL REFERENCES sessions(id) ON DELETE CASCADE,
    role            VARCHAR(10) NOT NULL                    -- "user" | "assistant"
                    CHECK (role IN ('user', 'assistant')),
    content         TEXT NOT NULL,
    created_at      TIMESTAMP DEFAULT NOW()
);

-- 7. Bảng user_profiles: Kết quả phân tích tính cách, thế mạnh từ Agent 2 (Evaluator)
-- ĐÃ LOẠI BỎ trường context_inferred theo yêu cầu
CREATE TABLE user_profiles (
    id                SERIAL PRIMARY KEY,
    session_id        UUID UNIQUE NOT NULL REFERENCES sessions(id) ON DELETE CASCADE,
    trait_scores      JSONB,                                  -- { "logical_thinking": 8, "creativity": 7, "favorite_subjects": ["Toán", "Anh"] }
    confidence_scores JSONB,                                  -- { "logical_thinking": 0.85, "creativity": 0.9 }
    is_ready          BOOLEAN DEFAULT FALSE,                  -- true = đủ dữ liệu để kích hoạt Agent 3 vẽ roadmap
    updated_at        TIMESTAMP DEFAULT NOW()
);

-- 8. Bảng roadmaps: Kết quả lộ trình học tập/nghề nghiệp chi tiết từ Agent 3 (Generator)
CREATE TABLE roadmaps (
    id                   SERIAL PRIMARY KEY,
    session_id           UUID UNIQUE NOT NULL REFERENCES sessions(id) ON DELETE CASCADE,
    user_profile_summary TEXT,                               -- tóm tắt ngắn gọn thế mạnh của học sinh dưới dạng văn bản
    paths                JSONB NOT NULL,                     -- mảng các bước đi, tổ hợp môn thi, trường ĐH/Cao đẳng gợi ý
    disclaimer           TEXT NOT NULL,                      -- lời khuyên/cảnh báo mang tính tham khảo cho học sinh
    generated_at         TIMESTAMP DEFAULT NOW()
);

ALTER TABLE career_tracks 
ADD COLUMN local_demand_signals JSONB, -- Lưu xu hướng tuyển dụng, kỹ năng thiếu hụt theo vùng miền
ADD COLUMN timeline_trends JSONB;      -- Lưu biến động nhu cầu tuyển dụng theo thời gian
