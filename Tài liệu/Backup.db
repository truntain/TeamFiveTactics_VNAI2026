-- ============================================================
-- SKILLCOMPASS — PostgreSQL Schema
-- Ghi chú:
--   Nhóm A: Agent 1 ghi (market data, chạy offline trước demo)
--   Nhóm B: NestJS ghi (user data, ghi trong runtime)
-- ============================================================


-- ============================================================
-- NHÓM A: MARKET DATA (Agent 1 offline pipeline ghi vào)
-- ============================================================

-- Bảng career_tracks: Danh sách tất cả ngành nghề
-- Agent 1 ghi, Agent 3 embed + ghi vector_id vào đây
CREATE TABLE career_tracks (
    id              SERIAL PRIMARY KEY,
    career_track    VARCHAR(100)    NOT NULL,               -- "Data Science", "Kỹ thuật Ô tô"
    track_type      VARCHAR(20)     NOT NULL                -- "academic" | "vocational"
                    CHECK (track_type IN ('academic', 'vocational')),
    description     TEXT,
    avg_salary_min  INTEGER,                                -- VND/tháng
    avg_salary_max  INTEGER,
    education_route TEXT,                                   -- "Đại học CNTT" | "Cao đẳng nghề 2 năm"
    typical_employers TEXT[],                               -- ["FPT", "VNG", "Viettel"]
    region_demand   JSONB,                                  -- { "HCM": "high", "HN": "medium" }
    vector_id       VARCHAR(100),                           -- ID trong Pinecone (để đối chiếu)
    created_at      TIMESTAMP DEFAULT NOW()
);

-- Bảng role_progressions: Lộ trình vị trí của từng career track
CREATE TABLE role_progressions (
    id              SERIAL PRIMARY KEY,
    career_track_id INTEGER NOT NULL REFERENCES career_tracks(id) ON DELETE CASCADE,
    level           VARCHAR(20) NOT NULL                    -- "Entry" | "Mid" | "Advanced"
                    CHECK (level IN ('Entry', 'Mid', 'Advanced')),
    title           VARCHAR(150) NOT NULL,                  -- "Data Analyst Intern"
    description     TEXT,
    sort_order      INTEGER DEFAULT 0                       -- thứ tự hiển thị
);

-- Bảng skill_trees: Kỹ năng cần thiết theo từng career track
CREATE TABLE skill_trees (
    id              SERIAL PRIMARY KEY,
    career_track_id INTEGER NOT NULL REFERENCES career_tracks(id) ON DELETE CASCADE,
    category        VARCHAR(50) NOT NULL                    -- "fundamentals" | "core_technologies" | "advanced_skills"
                    CHECK (category IN ('fundamentals', 'core_technologies', 'advanced_skills')),
    skill_name      VARCHAR(100) NOT NULL                   -- "Python", "PLC Siemens", "SQL"
);


-- ============================================================
-- NHÓM B: USER DATA (NestJS ghi trong runtime)
-- ============================================================
CREATE TABLE users (
    id              SERIAL PRIMARY KEY,
    username        VARCHAR(100) UNIQUE,                    -- Dùng cho login (custom JWT Auth)
    email           VARCHAR(255) UNIQUE NOT NULL,           -- Email đăng ký tài khoản
    password_hash   VARCHAR(255) NOT NULL,                  -- Mật khẩu mã hóa lưu trên DB của NestJS
    anonymous_id    UUID UNIQUE,                            -- Dùng để định danh nếu là người dùng vãng lai (không đăng nhập)
    created_at      TIMESTAMP DEFAULT NOW()
);

-- Bảng sessions: Mỗi phiên trò chuyện
CREATE TABLE sessions (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         INTEGER REFERENCES users(id) ON DELETE SET NULL,
    started_at      TIMESTAMP DEFAULT NOW(),
    ended_at        TIMESTAMP,
    is_complete     BOOLEAN DEFAULT FALSE                   -- true khi đã generate xong roadmap
);

-- Bảng conversation_messages: Backup lịch sử chat (Redis là primary, bảng này là backup)
-- NestJS ghi song song với Redis để đảm bảo không mất data
CREATE TABLE conversation_messages (
    id              SERIAL PRIMARY KEY,
    session_id      UUID NOT NULL REFERENCES sessions(id) ON DELETE CASCADE,
    role            VARCHAR(10) NOT NULL                    -- "user" | "assistant"
                    CHECK (role IN ('user', 'assistant')),
    content         TEXT NOT NULL,
    created_at      TIMESTAMP DEFAULT NOW()
);

-- Bảng user_profiles: Kết quả phân tích từ Agent 2 (Evaluator)
-- NestJS ghi mỗi khi nhận profile_update từ Agent 2
CREATE TABLE user_profiles (
    id              SERIAL PRIMARY KEY,
    session_id      UUID UNIQUE NOT NULL REFERENCES sessions(id) ON DELETE CASCADE,
    context_inferred VARCHAR(20)                            -- "highschool" | "vocational" | "college"
                    CHECK (context_inferred IN ('highschool', 'vocational', 'college')),
    trait_scores    JSONB,                                  -- { "creativity": 7, "teamwork": 5, ... }
    confidence_scores JSONB,                                -- { "creativity": 0.85, "teamwork": 0.9 }
    is_ready        BOOLEAN DEFAULT FALSE,                  -- true = đủ data để gọi Agent 3
    updated_at      TIMESTAMP DEFAULT NOW()
);

-- Bảng roadmaps: Kết quả đa lộ trình từ Agent 3
-- NestJS ghi sau khi nhận response từ Agent 3
CREATE TABLE roadmaps (
    id                   SERIAL PRIMARY KEY,
    session_id           UUID UNIQUE NOT NULL REFERENCES sessions(id) ON DELETE CASCADE,
    user_profile_summary TEXT,                              -- tóm tắt hồ sơ bằng ngôn ngữ tự nhiên
    paths                JSONB NOT NULL,                    -- mảng các lộ trình (xem cấu trúc bên dưới)
    disclaimer           TEXT NOT NULL,                     -- bắt buộc hiển thị cho user
    generated_at         TIMESTAMP DEFAULT NOW()
);

-- Cấu trúc JSONB của cột "paths" trong bảng roadmaps:
-- [
--   {
--     "path_id": 1,
--     "track_type": "academic",
--     "career_track": "Data Science",
--     "education_route": "Đại học CNTT",
--     "match_score": 88,
--     "why_it_fits": "Bạn có tư duy phân tích...",
--     "role_progression": [
--       { "level": "Entry", "title": "Data Analyst Intern", "description": "..." },
--       { "level": "Mid",   "title": "Senior Data Analyst", "description": "..." }
--     ],
--     "skill_tree": {
--       "fundamentals": ["Toán Thống kê", "Excel"],
--       "core_technologies": ["SQL", "Python"],
--       "advanced_skills": ["Machine Learning"]
--     }
--   },
--   {
--     "path_id": 2,
--     "track_type": "vocational",
--     ...
--   }
-- ]


-- ============================================================
-- INDEXES (tối ưu truy vấn thường dùng)
-- ============================================================

CREATE INDEX idx_sessions_user_id     ON sessions(user_id);
CREATE INDEX idx_messages_session_id  ON conversation_messages(session_id);
CREATE INDEX idx_profiles_session_id  ON user_profiles(session_id);
CREATE INDEX idx_roadmaps_session_id  ON roadmaps(session_id);
CREATE INDEX idx_tracks_type          ON career_tracks(track_type);
CREATE INDEX idx_roles_track_id       ON role_progressions(career_track_id);
CREATE INDEX idx_skills_track_id      ON skill_trees(career_track_id);

-- GIN index cho JSONB (tìm kiếm trong trait_scores, paths)
CREATE INDEX idx_profiles_traits      ON user_profiles USING GIN (trait_scores);
CREATE INDEX idx_roadmaps_paths       ON roadmaps USING GIN (paths);


